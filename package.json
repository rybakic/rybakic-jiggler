{
  "name": "rybakic-jiggler",
  "version": "1.0.3",
  "author": "RYBAKIČ",
  "private": true,
  "description": "Desktop mouse jiggler.",
  "license": "UNLICENSED",
  "packageManager": "npm@11.7.0",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "electron": "wait-on http://localhost:4200 && electron .",
    "dev": "concurrently -k \"ng serve\" \"npm run electron\"",
    "build": "ng build --base-href ./",
    "build:web": "ng build --base-href ./",
    "build:win": "npm run build:web && electron-builder -w --x64 --publish never",
    "build:mac": "npm run build:web && electron-builder -m --universal --publish never",
    "build:all": "npm run build:web && electron-builder -w --x64 -m --universal --publish never",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "dependencies": {
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@taiga-ui/addon-charts": "^4.73.0",
    "@taiga-ui/addon-commerce": "^4.73.0",
    "@taiga-ui/addon-doc": "^4.73.0",
    "@taiga-ui/addon-mobile": "^4.73.0",
    "@taiga-ui/addon-table": "^4.73.0",
    "@taiga-ui/cdk": "^4.73.0",
    "@taiga-ui/core": "^4.73.0",
    "@taiga-ui/event-plugins": "^4.0.2",
    "@taiga-ui/icons": "^4.73.0",
    "@taiga-ui/kit": "^4.73.0",
    "@taiga-ui/layout": "^4.73.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "concurrently": "^9.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.0.0",
    "less": "^4.5.1",
    "@tailwindcss/postcss": "^4.2.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.4"
  },
  "build": {
    "productName": "RYBAKIČ Mouse Jiggler",
    "appId": "com.rybakic.mousejiggler",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "public/**",
      "electron/**",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/active.ico",
      "signAndEditExecutable": true
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns",
      "artifactName": "setup_macOS.${ext}"
    },
    "nsis": {
      "artifactName": "setup_win64.${ext}",
      "installerIcon": "public/disable.ico",
      "uninstallerIcon": "public/disable.ico",
      "installerHeaderIcon": "public/disable.ico",
      "createDesktopShortcut": true,
      "shortcutName": "RYBAKIČ Mouse Jiggler",
      "uninstallDisplayName": "RYBAKIČ Mouse Jiggler"
    }
  }
}
